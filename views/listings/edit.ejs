<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wanderlust</title>
</head>
<body>
    <h3>edit your details here</h3>
    <form method="POST" action="/listings/<%=list._id%>?_method=PUT">
        <input name="listing[title]" value="<%=list.title%>"><br><br>
         <textarea name="listing[description]"><%=list.description%></textarea><br><br>
         <input name="listing[image][url]" value="<%=list.image.url%> "><br><br>
          <input name="listing[price]" value="<%=list.price%>" type="number"><br><br>
           <input name="listing[location]" value="<%=list.location%> "><br><br>
            <input name="listing[country]" value="<%=list.country%> "><br><br>
        <button>submit</button>
    </form>
    
</body>
</html>