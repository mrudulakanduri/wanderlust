 <% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
    <div class="col-8 offset-2">
     <h3>list details</h3>
     </div>
<div class="card col-5 offset-2">
  <img src="<%=list.image.url%>" class="card-img-top  show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
      <b><%= list.title %></b><br>
      <%= list.description %><br>
      &#x20B9;<%= list.price.toLocaleString("en-IN") %><br>
      <%= list.location %><br>
      <%= list.country %>
    </p>
    
    <div class="d-flex gap-2">
  <a href="/listings/<%=list._id%>/edit" class="btn btn-dark btn-add">Edit</a>
  <form method="post" action="/listings/<%=list._id%>?_method=DELETE">
    <button class="btn btn-dark">delete</button>
  </form>
</div>
    
   
  </div>
</div>
</div>


</body>
 