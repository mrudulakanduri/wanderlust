 <% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
    <div class="col-8 offset-2">
     <h3><%= list.title %></h3>
     </div>
<div class="card listing-card col-5 offset-2">
  <img src="<%=list.image.url%>" class="card-img-top  show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
      <%= list.description %><br>
      &#x20B9;<%= list.price.toLocaleString("en-IN") %><br>
      <%= list.location %><br>
      <%= list.country %>
    </p>
    
    <div class="d-flex gap-2">
  <a href="/listings/<%=list._id%>/edit" class="btn btn-dark btn-add">Edit</a>
  <form method="post" action="/listings/<%=list._id%>?_method=DELETE">
    <button class="btn btn-dark">delete</button>
  </form>
</div>
</div>
</div>
</div>
</body>
 


  <div class="col-8 offset-2 mt-3 mb-3">
    <h4>leave a review</h4>
    <form method="post" action="/listings/<%=list._id%>/reviews" novalidate class="needs-validation">
      <div>
        <label for="rating" class="form-label">Rating</label>
        <input name="review[rating]" type="range" min="1" max="5" id="rating" class="form-range" >
      </div>
    <div>
      <label for="comments" class="form-label">comments</label>
      <textarea type="text" name="review[comment]" id="comment" rows="10" cols="30" class="form-control" required></textarea>
    </div>
    <br>
    
    <button class="btn btn-dark">submit</button>
  </form>
 
  
  <h4>Reviews</h4>
  <div class="row">
      <% for (let review of list.review) { %>
        <div class="card col-5 ms-2 mb-2">
          <h5 class="card-title">Mrudula</h5>
          <p class="card-text"><%= review.comment %> </p>
          <p class="card-text"> <%= review.rating %></p>
          <form method="post" action="/listings/<%=list._id%>/reviews/<%=review._id%>?_method=DELETE">
            <button class="btn btn-dark mb-3">delete</button>
          </form>
    </div>
    <% } %>
  </div>
  </div>

     

 
 