<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>wanderlust</title>
</head>
<body>
    <h3>list details</h3>
    <ul>
        <li><%= list.title %></li>
        <li><%= list.description %></li>
        <li>&#x20B9;<%= list.price.toLocaleString("en-IN") %></li>
        <li><%= list.location %></li>
        <li><%= list.country %></li>
        
    </ul>
     <a href="/listings/<%=list._id%>/edit">Edit your details</a>
     <form method="post" action="/listings/<%=list._id%>?_method=DELETE">
        <button>delete</button>
     </form>

</body>
</html>